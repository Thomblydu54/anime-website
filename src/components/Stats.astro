---
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";
---

<section class="py-24">

  <Container>

    <SectionTitle
      title="Le projet en chiffres"
      subtitle="Toutes les statistiques sont synchronisées automatiquement avec GitHub."
    />

    <div class="stats-grid">

      <div class="stat-card">

        <div class="stat-glow"></div>

        <div class="stat-icon">⭐</div>

        <h3 id="stars" class="stat-value">0</h3>

        <p class="stat-label">
          Étoiles GitHub
        </p>

      </div>

      <div class="stat-card">

        <div class="stat-glow"></div>

        <div class="stat-icon">🍴</div>

        <h3 id="forks" class="stat-value">0</h3>

        <p class="stat-label">
          Forks
        </p>

      </div>

      <div class="stat-card">

        <div class="stat-glow"></div>

        <div class="stat-icon">👀</div>

        <h3 id="watchers" class="stat-value">0</h3>

        <p class="stat-label">
          Watchers
        </p>

      </div>

      <div class="stat-card">

        <div class="stat-glow"></div>

        <div class="stat-icon">⬇️</div>

        <h3 id="downloads" class="stat-value">0</h3>

        <p class="stat-label">
          Téléchargements
        </p>

      </div>

    </div>

  </Container>

</section>