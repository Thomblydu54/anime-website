---
const BASE_URL = import.meta.env.BASE_URL;

const screenshots = [
  `${BASE_URL}screenshots/home.jpg`,
  `${BASE_URL}screenshots/planning.jpg`,
  `${BASE_URL}screenshots/profile.jpg`,
  `${BASE_URL}screenshots/player.jpg`,
];
---

<div class="phone-wrapper">
  <div class="phone">

    <div class="phone-notch"></div>

    <div class="phone-glare"></div>

    {
      screenshots.map((image, index) => (
        <img
          src={image}
          alt={`Capture ${index + 1}`}
          loading={index === 0 ? "eager" : "lazy"}
          class={`screen ${index === 0 ? "active" : ""}`}
        />
      ))
    }

  </div>
</div>

<script>
  const phone = document.currentScript?.previousElementSibling;

  if (phone) {

    const screens = phone.querySelectorAll(".screen");

    let current = 0;

    setInterval(() => {

      screens[current].classList.remove("active");

      current = (current + 1) % screens.length;

      screens[current].classList.add("active");

    }, 3500);

  }
</script>

<style>

.phone-wrapper{

display:flex;

justify-content:center;

align-items:center;

animation:float 5s ease-in-out infinite;

}

.phone{

position:relative;

width:380px;

aspect-ratio:9/19;

border-radius:42px;

overflow:hidden;

background:#000;

border:10px solid #151515;

box-shadow:
0 40px 80px rgba(0,0,0,.6),
0 0 80px rgba(139,92,246,.30);

transform:perspective(1200px) rotateY(-8deg) rotateX(3deg);

}

.phone-notch{

position:absolute;

top:10px;

left:50%;

transform:translateX(-50%);

width:120px;

height:24px;

background:#111;

border-radius:999px;

z-index:20;

}

.phone-glare{

position:absolute;

top:0;

left:-40%;

width:40%;

height:100%;

background:linear-gradient(
90deg,
transparent,
rgba(255,255,255,.08),
transparent
);

transform:skewX(-20deg);

animation:shine 6s linear infinite;

z-index:15;

pointer-events:none;

}

.screen{

position:absolute;

inset:0;

width:100%;

height:100%;

object-fit:cover;

opacity:0;

transition:opacity .8s ease;

}

.screen.active{

opacity:1;

}

@keyframes float{

0%,100%{

transform:translateY(0);

}

50%{

transform:translateY(-12px);

}

}

@keyframes shine{

0%{

left:-40%;

}

100%{

left:140%;

}

}

</style>