---
import Container from "./Container.astro";
import Button from "./Button.astro";
import { getLatestRelease } from "../lib/github";

const release = await getLatestRelease();

const formattedDate = new Date(release.published_at).toLocaleDateString(
  "fr-FR",
  {
    day: "numeric",
    month: "long",
    year: "numeric",
  }
);
---

<section class="py-32">

  <Container>

    <div class="mx-auto max-w-4xl">

      <div class="text-center">

        <span class="rounded-full bg-violet-500/10 px-4 py-2 text-sm text-violet-300 border border-violet-500/20">
          🚀 Dernière mise à jour
        </span>

        <h2 class="mt-6 text-5xl font-black">
          {release.tag_name}
        </h2>

        <p class="mt-3 text-zinc-500">
          Publiée le {formattedDate}
        </p>

      </div>

      <div class="mt-12 rounded-[32px] border border-white/10 bg-white/5 p-10 backdrop-blur-xl">

        <h3 class="text-2xl font-bold">
          {release.name}
        </h3>

        <div class="mt-8 whitespace-pre-line leading-8 text-zinc-300">

          {release.body || "Aucune note de version disponible."}

        </div>

        <div class="mt-10 flex justify-center">

          <Button href="https://github.com/Thomblydu54/Anime/releases/latest/download/Anime.apk">
            ⬇ Télécharger cette version
          </Button>

        </div>

      </div>

    </div>

  </Container>

<script>

import "../scripts/github";

</script>

</section>