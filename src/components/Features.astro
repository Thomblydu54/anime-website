---
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";

const features = [
  {
    icon: "🎬",
    title: "Lecture intégrée",
    description:
      "Regardez vos animes directement depuis l'application grâce à un lecteur moderne et fluide."
  },
  {
    icon: "📅",
    title: "Planning",
    description:
      "Consultez les prochaines sorties de vos séries favorites et ne manquez aucun épisode."
  },
  {
    icon: "❤️",
    title: "Favoris",
    description:
      "Ajoutez vos animes préférés à votre bibliothèque personnelle pour les retrouver rapidement."
  },
  {
    icon: "⬇️",
    title: "Téléchargement",
    description:
      "Téléchargez vos épisodes pour les regarder hors connexion où que vous soyez."
  },
  {
    icon: "🏆",
    title: "Succès",
    description:
      "Débloquez des succès et suivez votre progression directement dans l'application."
  },
  {
    icon: "⚡",
    title: "Rapide",
    description:
      "Une interface optimisée offrant une navigation fluide et agréable sur Android."
  }
];
---

<section id="features" class="py-32">

  <Container>

    <SectionTitle
      title="Fonctionnalités"
      subtitle="Tout ce qu'il faut pour regarder, suivre et gérer vos animes dans une seule application."
    />

    <div class="mt-16 grid gap-8 md:grid-cols-2 xl:grid-cols-3">

      {
        features.map((feature) => (

          <article
            class="group flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-xl transition-all duration-300 hover:-translate-y-2 hover:border-violet-500/40 hover:bg-white/10 hover:shadow-[0_20px_60px_rgba(139,92,246,.20)]">

            <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-violet-500/10 text-4xl transition-transform duration-300 group-hover:scale-110">
              {feature.icon}
            </div>

            <h3 class="mt-8 text-2xl font-bold">
              {feature.title}
            </h3>

            <p class="mt-4 flex-1 leading-7 text-zinc-400">
              {feature.description}
            </p>

          </article>

        ))
      }

    </div>

  </Container>

</section>