---
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";

const BASE_URL = import.meta.env.BASE_URL;

const screenshots = [
  `${BASE_URL}screenshots/home.jpg`,
  `${BASE_URL}screenshots/profile.jpg`,
  `${BASE_URL}screenshots/historique.jpg`,
  `${BASE_URL}screenshots/téléchargement.jpg`,
  `${BASE_URL}screenshots/liste.jpg`,
  `${BASE_URL}screenshots/player.jpg`,
  `${BASE_URL}screenshots/îcone.jpg`,
  `${BASE_URL}screenshots/planning.jpg`,
];
---

<section id="screenshots" class="py-32">

  <Container>

    <SectionTitle
      title="Captures d'écran"
      subtitle="Découvrez l'interface moderne d'Anime avant même de télécharger l'application."
    />

    <div class="mt-20 grid gap-10 sm:grid-cols-2 xl:grid-cols-4">

      {
        screenshots.map((image, index) => (

          <div
            class="group flex justify-center">

            <div
              class="relative overflow-hidden rounded-[38px] border border-white/10 bg-white/5 p-2 backdrop-blur-xl shadow-[0_20px_60px_rgba(0,0,0,.35)] transition-all duration-500 hover:-translate-y-3 hover:border-violet-500/40 hover:shadow-[0_30px_80px_rgba(139,92,246,.25)]">

              <!-- Reflet -->

              <div
                class="pointer-events-none absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-60">
              </div>

              <!-- Image -->

              <img
                src={image}
                alt={`Capture d'écran ${index + 1}`}
                loading="lazy"
                class="w-[240px] rounded-[30px] transition duration-500 group-hover:scale-[1.02]"
              />

            </div>

          </div>

        ))
      }

    </div>

  </Container>

</section>