---
interface Props {
  title: string;
  subtitle?: string;
}

const {
  title,
  subtitle
} = Astro.props;
---

<div class="mx-auto mb-20 max-w-3xl text-center">

  <!-- Badge -->

  <div class="mb-6 flex justify-center">

    <span class="rounded-full border border-violet-500/20 bg-violet-500/10 px-4 py-2 text-sm font-medium text-violet-300">
      ✨ Anime
    </span>

  </div>

  <!-- Titre -->

  <h2
    class="text-4xl font-black leading-tight tracking-tight md:text-5xl">

    {title}

  </h2>

  <!-- Trait décoratif -->

  <div class="mx-auto mt-6 h-1 w-24 rounded-full bg-gradient-to-r from-violet-500 to-fuchsia-500"></div>

  <!-- Sous-titre -->

  {
    subtitle && (

      <p
        class="mx-auto mt-8 max-w-2xl text-lg leading-8 text-zinc-400">

        {subtitle}

      </p>

    )
  }

</div>